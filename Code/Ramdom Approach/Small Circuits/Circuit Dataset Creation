th(\"v\") or line.startswith(\"x\"):\n","            parts = line.split()\n","            gate = parts[0]\n","            vars_ = parts[1:]\n","            circuit_data[\"gates\"].append({\"gate\": gate, \"vars\": vars_})\n","\n","    circuit_data[\"circuit_name\"] = os.path.basename(filepath).replace(\".real\", \"\")\n","    return circuit_data\n"],"metadata":{"id":"njf85klCifjZ","executionInfo":{"status":"ok","timestamp":1759901035645,"user_tz":-330,"elapsed":9,"user":{"displayName":"Avanti Thale","userId":"13650921355253076907"}}},"execution_count":3,"outputs":[]},{"cell_type":"code","source":["def build_combined_dataset(folder, csv_path=None, json_path=None):\n","    dataset = []\n","    for filename in os.listdir(folder):\n","        if filename.endswith(\".real\"):\n","            filepath = os.path.join(folder, filename)\n","            parsed = parse_realization_file(filepath)\n","            dataset.append(parsed)\n","\n","    df = pd.DataFrame(dataset)\n","\n","    if csv_path:\n","        os.makedirs(os.path.dirname(csv_path), exist_ok=True)\n","        df.to_csv(csv_path, index=False)\n","\n","    if json_path:\n","        os.makedirs(os.path.dirname(json_path), exist_ok=True)\n","        with open(json_path, \"w\") as f:\n","            json.dump(dataset, f, indent=4)\n","\n","    return df"],"metadata":{"id":"M-y_c4SNiiRr","executionInfo":{"status":"ok","timestamp":1759901035659,"user_tz":-330,"elapsed":13,"user":{"displayName":"Avanti Thale","userId":"13650921355253076907"}}},"execution_count":4,"outputs":[]},{"cell_type":"code","source":["# -------- Run Example --------\n","# Put all your RevLib benchmark files inside \"benchmarks/\" folder\n","folder = \"/content/drive/MyDrive/Dissertation Work/Research Work/Benchmarks/Benchmarks Used in Base Paper/Test\"\n","csv_path=\"/content/drive/MyDrive/Dissertation Work/Research Work/Datasets/test_circuits.csv\"\n","json_path=\"/content/drive/MyDrive/Dissertation Work/Research Work/Datasets/test_circuits.json